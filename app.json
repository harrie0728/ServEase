{
  "expo": {
    "name": "ServEase",
    "slug": "servease",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f6f6f6"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "com.servease.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "plugins": [
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "9b2ea33a-5d34-437b-bad5-97bfd4719b8c"
      }
    }
  }
}
